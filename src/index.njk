---
layout: base.njk
permalink: "index.html"
---
{% set analysis = collections.articles | selectattr("data.section", "equalto", "Analysis") %}
{% set lightReading = collections.articles | selectattr("data.section", "equalto", "Light Reading") %}
{% set featured = collections.articles | selectattr("data.featured", "equalto", true) | first %}
{% if not featured %}
  {% set featured = collections.articles | selectattr("data.order", "equalto", 1) | first %}
{% endif %}

  <!-- Nav bar -->
  <nav class="nav-bar" aria-label="Sections">
    <div class="container">
      <div class="nav-bar__inner">
        <a href="#cover" class="active">Cover Story</a>
        <a href="#in-this-issue">In This Issue</a>
        <a href="contributors.html">Contributors</a>
        <div class="nav-bar__actions">
          <a href="{{ site.signInUrl }}" data-signin>Sign in</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Subscribe banner -->
  <div class="container">
    <div class="subscribe-banner">
      <div class="subscribe-banner__text">
        <strong>Subscribe to the Circular</strong> — New issues delivered fortnightly.
      </div>
      <button type="button" class="btn btn--sm btn--filled" data-subscribe>Subscribe</button>
    </div>
  </div>

  <main>
    <div class="container">
      <div class="page-layout">

        <!-- Cover story -->
        <div class="page-layout__main">
          <section class="hero--cover" id="cover" aria-label="Cover story">
            <div class="cover-kicker">
              <span class="cover-kicker__label">Cover Story</span>
              <span class="cover-kicker__rule"></span>
              <span class="cover-kicker__issue">Vol. {{ site.volume }} &middot; No. {{ site.issue }}</span>
            </div>

            <article class="article-card article-card--cover">
              {% if featured.data.leadImage %}
              <figure class="article-card--cover__figure">
                <img src="articles/{{ featured.data.leadImage.src }}" alt="{{ featured.data.leadImage.alt | default('') }}">
                {% if featured.data.leadImage.caption %}
                <figcaption>{{ featured.data.leadImage.caption | safe }}</figcaption>
                {% endif %}
              </figure>
              {% endif %}

              <div class="article-card__section">{{ featured.data.section }} &middot; {{ featured.data.subsection }}</div>
              <h1 class="article-card__title">
                <a href="articles/{{ featured.fileSlug }}.html">{{ featured.data.title }}</a>
              </h1>
              <p class="article-card__dek">{{ featured.data.dek | safe }}</p>
              <p class="article-card__byline">By {{ featured.data.author }} &nbsp;&middot;&nbsp; {{ featured.data.pubDate }}</p>
              <p class="article-card__readlink">
                <a href="articles/{{ featured.fileSlug }}.html">Read the cover story &rarr;</a>
              </p>
            </article>
          </section>

          <!-- Contributors blurb -->
          <section class="cover-footnote" id="contributors-blurb">
            <p>
              <em>The Fortnightly Circular</em> publishes longform analysis and occasional lighter fare
              on the intersections of technology, geopolitics, finance, and culture.
              <a href="contributors.html">Meet the contributors &rarr;</a>
            </p>
          </section>
        </div>

        <!-- Sidebar: In This Issue -->
        <aside class="page-layout__sidebar" id="in-this-issue" aria-label="In this issue">
          <button class="toc-toggle btn btn--sm"
                  aria-expanded="false"
                  aria-controls="toc-sidebar-content">In This Issue</button>
          <div class="toc-sidebar" id="toc-sidebar-content">
            <div class="toc-sidebar__title">In This Issue</div>

            <div class="toc-sidebar__section">Analysis</div>
            <ul class="toc-sidebar__list">
              {% for article in analysis %}
                {% if not article.data.featured %}
                <li class="toc-item">
                  <a href="articles/{{ article.fileSlug }}.html" class="toc-item__link">
                    <span class="toc-item__title">{{ article.data.title }}</span>
                    {% if article.data.subsection %}
                    <span class="toc-item__kicker">{{ article.data.subsection }}</span>
                    {% endif %}
                    {% if article.data.dek %}
                    <span class="toc-item__dek">{{ article.data.dek | safe }}</span>
                    {% endif %}
                  </a>
                </li>
                {% endif %}
              {% endfor %}
            </ul>

            <div class="toc-sidebar__section">Light Reading</div>
            <ul class="toc-sidebar__list">
              {% for article in lightReading %}
                {% if not article.data.featured %}
                <li class="toc-item">
                  <a href="articles/{{ article.fileSlug }}.html" class="toc-item__link">
                    <span class="toc-item__title">{{ article.data.title }}</span>
                    {% if article.data.subsection %}
                    <span class="toc-item__kicker">{{ article.data.subsection }}</span>
                    {% endif %}
                    {% if article.data.dek %}
                    <span class="toc-item__dek">{{ article.data.dek | safe }}</span>
                    {% endif %}
                  </a>
                </li>
                {% endif %}
              {% endfor %}
            </ul>

            <div class="toc-sidebar__issue-footer">{{ site.season }}</div>
          </div>
        </aside>

      </div>
    </div>
  </main>
