---
layout: base.njk
permalink: "index.html"
---
{% set analysis = collections.articles | selectattr("data.section", "equalto", "Analysis") %}
{% set lightReading = collections.articles | selectattr("data.section", "equalto", "Light Reading") %}
{% set featured = collections.articles | selectattr("data.featured", "equalto", true) | first %}
{% if not featured %}
  {% set featured = collections.articles | selectattr("data.order", "equalto", 1) | first %}
{% endif %}

<main>
  <div class="container">
    <div class="front-page">

      <!-- Cover story -->
      <article class="cover-story" aria-label="Cover story">
        <div class="cover-story__kicker">
          <span>{{ featured.data.section }}</span>
          {% if featured.data.subsection %}<span class="sep">·</span><span>{{ featured.data.subsection }}</span>{% endif %}
        </div>

        <h2 class="cover-story__title">
          <a href="articles/{{ featured.fileSlug }}.html">{{ featured.data.title }}</a>
        </h2>

        {% if featured.data.dek %}
        <p class="cover-story__dek">{{ featured.data.dek | safe }}</p>
        {% endif %}

        <p class="cover-story__byline">By {{ featured.data.author }}</p>

        <div class="cover-story__body">
          {{ featured.templateContent | firstParagraphs(2) | safe }}
        </div>

        <a class="cover-story__readmore" href="articles/{{ featured.fileSlug }}.html">Continue reading →</a>
      </article>

      <!-- "In This Number" sidebar -->
      <aside class="in-this-number" aria-label="In this number">
        <div class="in-this-number__heading">In This Number</div>

        {% if analysis | length %}
        <div class="in-this-number__section">Analysis</div>
        <ul class="in-this-number__list">
          {% for article in analysis %}
            {% if not article.data.featured %}
            <li class="in-this-number__item">
              <span class="in-this-number__author">{{ article.data.author }}</span>
              <a class="in-this-number__title" href="articles/{{ article.fileSlug }}.html">{{ article.data.title }}</a>
              {% if article.data.dek %}
              <span class="in-this-number__dek">{{ article.data.dek | safe }}</span>
              {% endif %}
            </li>
            {% endif %}
          {% endfor %}
        </ul>
        {% endif %}

        {% if lightReading | length %}
        <div class="in-this-number__section">Light Reading</div>
        <ul class="in-this-number__list">
          {% for article in lightReading %}
            {% if not article.data.featured %}
            <li class="in-this-number__item">
              <span class="in-this-number__author">{{ article.data.author }}</span>
              <a class="in-this-number__title" href="articles/{{ article.fileSlug }}.html">{{ article.data.title }}</a>
              {% if article.data.dek %}
              <span class="in-this-number__dek">{{ article.data.dek | safe }}</span>
              {% endif %}
            </li>
            {% endif %}
          {% endfor %}
        </ul>
        {% endif %}
      </aside>

    </div>

    <section class="previous-numbers" aria-label="Previous numbers">
      <div class="previous-numbers__heading">Previous Numbers</div>
      <p>This is the inaugural number. Future issues will be listed here.</p>
    </section>
  </div>
</main>
