---
layout: base.njk
permalink: "index.html"
---
{% set analysis = collections.articles | selectattr("data.section", "equalto", "Analysis") %}
{% set lightReading = collections.articles | selectattr("data.section", "equalto", "Light Reading") %}

  <!-- Nav bar -->
  <nav class="nav-bar" aria-label="Sections">
    <div class="container">
      <div class="nav-bar__inner">
        <a href="#analysis" class="active">Analysis</a>
        <a href="#light-reading">Light Reading</a>
        <a href="contributors.html">Contributors</a>
        <div class="nav-bar__actions">
          <a href="{{ site.signInUrl }}" data-signin>Sign in</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Subscribe banner -->
  <div class="container">
    <div class="subscribe-banner">
      <div class="subscribe-banner__text">
        <strong>Subscribe to the Circular</strong> — New issues delivered fortnightly.
      </div>
      <button type="button" class="btn btn--sm btn--filled" data-subscribe>Subscribe</button>
    </div>
  </div>

  <main>
    <div class="container">
      <div class="page-layout">

        <!-- Content column -->
        <div class="page-layout__main">

          <!-- HERO: featured articles -->
          <section class="hero" aria-label="Featured">
            <div class="hero__grid">

              <!-- Lead feature -->
              <div class="hero__lead">
                {% set lead = collections.articles | selectattr("data.order", "equalto", 3) | first %}
                <article class="article-card article-card--hero">
                  <div class="article-card__section">{{ lead.data.section }} &middot; {{ lead.data.subsection }}</div>
                  <h2 class="article-card__title">
                    <a href="articles/{{ lead.fileSlug }}.html">{{ lead.data.title }}</a>
                  </h2>
                  <p class="article-card__byline">{{ lead.data.author }} — {{ lead.data.pubDate }}</p>
                  <p class="article-card__dek">{{ lead.data.dek | safe }}</p>
                </article>
              </div>

              <!-- Secondary features -->
              <div class="hero__secondary">
                {% set secondary1 = collections.articles | selectattr("data.order", "equalto", 2) | first %}
                <article class="article-card article-card--small">
                  <div class="article-card__section">{{ secondary1.data.section }} &middot; {{ secondary1.data.subsection }}</div>
                  <h3 class="article-card__title">
                    <a href="articles/{{ secondary1.fileSlug }}.html">{{ secondary1.data.title }}</a>
                  </h3>
                  <p class="article-card__byline">{{ secondary1.data.author }} — {{ secondary1.data.pubDate }}</p>
                  <p class="article-card__dek">{{ secondary1.data.dek | safe }}</p>
                </article>

                {% set secondary2 = collections.articles | selectattr("data.order", "equalto", 4) | first %}
                <article class="article-card article-card--small">
                  <div class="article-card__section">{{ secondary2.data.section }} &middot; {{ secondary2.data.subsection }}</div>
                  <h3 class="article-card__title">
                    <a href="articles/{{ secondary2.fileSlug }}.html">{{ secondary2.data.title }}</a>
                  </h3>
                  <p class="article-card__byline">{{ secondary2.data.author }} — {{ secondary2.data.pubDate }}</p>
                  <p class="article-card__dek">{{ secondary2.data.dek | safe }}</p>
                </article>
              </div>

            </div>
          </section>

          <hr class="rule--heavy rule--accent" style="margin: 0 0 0.5rem;">

          <!-- ANALYSIS section -->
          <section class="section-block" id="analysis">
            <div class="section-block__header">
              <h2 class="section-block__name">Analysis</h2>
              <div class="section-block__rule"></div>
            </div>
            <div class="section-block__grid">
              {% for article in analysis %}
              <article class="article-card">
                <div class="article-card__section">{{ article.data.subsection }}</div>
                <h3 class="article-card__title">
                  <a href="articles/{{ article.fileSlug }}.html">{{ article.data.title }}</a>
                </h3>
                <p class="article-card__byline">{{ article.data.author | default(article.data.pubDate) }}</p>
                <p class="article-card__dek">{{ article.data.dek | safe }}</p>
                <p class="mt-2"><a href="articles/{{ article.fileSlug }}.html">Read &rarr;</a></p>
              </article>
              {% endfor %}
            </div>
          </section>

          <!-- LIGHT READING section -->
          <section class="section-block" id="light-reading">
            <div class="section-block__header">
              <h2 class="section-block__name">Light Reading</h2>
              <div class="section-block__rule"></div>
            </div>
            <div class="section-block__grid">
              {% for article in lightReading %}
              <article class="article-card">
                <div class="article-card__section">{{ article.data.subsection }}</div>
                <h3 class="article-card__title">
                  <a href="articles/{{ article.fileSlug }}.html">{{ article.data.title }}</a>
                </h3>
                <p class="article-card__byline">{{ article.data.pubDate }}</p>
                <p class="article-card__dek">{{ article.data.dek | safe }}</p>
                <p class="mt-2"><a href="articles/{{ article.fileSlug }}.html">Read &rarr;</a></p>
              </article>
              {% endfor %}
            </div>
          </section>

          <!-- CONTRIBUTORS link -->
          <section class="section-block" id="contributors" style="padding-bottom:0; border-bottom:none;">
            <p style="max-width:600px; font-size:0.95rem; color:var(--ink-muted); line-height:1.75;">
              <em>Karam &amp; Sprague&rsquo;s Fortnightly Circular</em> publishes longform analysis and occasional lighter fare on the intersections of technology, geopolitics, finance, and culture.
              <a href="contributors.html">Meet the contributors &rarr;</a>
            </p>
          </section>

        </div>

        <!-- Sidebar -->
        <aside class="page-layout__sidebar" aria-label="Table of contents">
          <button class="toc-toggle btn btn--sm"
                  aria-expanded="false"
                  aria-controls="toc-sidebar-content">In This Issue</button>
          <div class="toc-sidebar" id="toc-sidebar-content">
            <div class="toc-sidebar__title">In This Issue</div>

            <div class="toc-sidebar__section">Analysis</div>
            <ul class="toc-sidebar__list">
              {% for article in analysis %}
              <li><a href="articles/{{ article.fileSlug }}.html">{{ article.data.title }}{% if article.data.subsection %} — <em>{{ article.data.subsection }}</em>{% endif %}</a></li>
              {% endfor %}
            </ul>

            <div class="toc-sidebar__section">Light Reading</div>
            <ul class="toc-sidebar__list">
              {% for article in lightReading %}
              <li><a href="articles/{{ article.fileSlug }}.html">{{ article.data.title }}</a></li>
              {% endfor %}
            </ul>

            <div style="margin-top:1.2rem; font-size:0.78rem; color:var(--ink-light); font-family:var(--font-sans);">
              {{ site.season }}
            </div>
          </div>
        </aside>

      </div>
    </div>
  </main>
