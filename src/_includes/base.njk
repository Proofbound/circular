<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ pageTitle | default(site.title) }}{% endif %}</title>
  <meta name="description" content="{{ dek | default(description) | default(site.description) }}">
  <link rel="stylesheet" href="https://brand.proofbound.com/proofbound-design-system/proofbound.css">
  <link rel="stylesheet" href="{{ '../' if isArticle else '' }}css/style.css">
</head>
<body>

  {% if isArticle %}
  <div class="topnav">
    <div class="container">
      <a href="../index.html">The Fortnightly Circular</a>
      <span class="topnav__sep">·</span>
      <a href="../index.html">No. {{ site.issue }}</a>
      <span class="topnav__sep">·</span>
      <a href="../contributors.html">Contributors</a>
      <a href="{{ site.signInUrl }}" class="topnav__signin" data-signin>Sign in</a>
    </div>
  </div>
  {% endif %}

  <header class="masthead">
    <a href="{{ '../' if isArticle else '' }}index.html" class="masthead__link">
      <h1 class="masthead__title">The Fortnightly Circular</h1>
      <span class="masthead__subtitle">Conducted for the Benefit of Persons of Discernment &amp; Enquiring Disposition</span>
    </a>
    <div class="masthead__meta">
      <span>Vol. {{ site.volume }}</span>
      <span>No. {{ site.issue }}</span>
      <span>{{ site.season }}</span>
    </div>
  </header>

  {{ content | safe }}

  <footer class="site-footer">
    <div class="container">
      <div class="site-footer__subscribe">
        <h2 class="site-footer__subscribe-heading">Subscribe to the Circular</h2>
        <p class="site-footer__subscribe-dek">New numbers delivered fortnightly, by electronic post.</p>
        <form class="subscribe-form" id="subscribe-form"
              method="post"
              action="{{ site.platformApiUrl }}/subscribe"
              onsubmit="return false">
          <input type="email" name="email" placeholder="your@email.address" aria-label="Email address" required>
          <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-10000px">
          {% if site.turnstileSiteKey %}
          <div class="cf-turnstile subscribe-form__turnstile" data-sitekey="{{ site.turnstileSiteKey }}" data-size="flexible" data-theme="light"></div>
          {% endif %}
          <button type="submit">Subscribe</button>
        </form>
        <div class="subscribe-form__status" id="subscribe-status" aria-live="polite"></div>
      </div>
      <div class="site-footer__meta">
        <span class="site-footer__brand">The Fortnightly Circular</span>
        Vol. {{ site.volume }} &middot; No. {{ site.issue }} &middot; {{ site.season }}
        &nbsp;&middot;&nbsp;
        <a href="{{ '../' if isArticle else '' }}contributors.html">Contributors</a>
        <div class="site-footer__colophon">
          <span>Published by</span>
          <a href="https://proofbound.com" class="site-footer__colophon-link" aria-label="Proofbound">
            <img src="https://brand.proofbound.com/proofbound-design-system/assets/proofbound-logo.svg" alt="" class="site-footer__colophon-logo" width="18" height="18">
            <span class="site-footer__colophon-name">Proofbound</span>
          </a>
        </div>
      </div>
    </div>
  </footer>

  <p class="print-footer">The Fortnightly Circular &middot; No. {{ site.issue }} &middot; {{ site.season }}</p>

  <!-- Supabase JS client (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  {% if site.turnstileSiteKey %}
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  {% endif %}
  <script>
    window.__CIRCULAR__ = {
      supabaseUrl:     "{{ site.supabaseUrl }}",
      supabaseAnonKey: "{{ site.supabaseAnonKey }}",
      platformApiUrl:  "{{ site.platformApiUrl }}",
      turnstileSiteKey:"{{ site.turnstileSiteKey }}"
    };
  </script>
  <script src="{{ '../' if isArticle else '' }}js/circular.js" defer></script>
</body>
</html>
