<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ pageTitle | default(site.title) }}{% endif %}</title>
  <meta name="description" content="{{ dek | default(description) | default(site.description) }}">
  <link rel="stylesheet" href="https://brand.proofbound.com/proofbound-design-system/proofbound.css">
  <link rel="stylesheet" href="{{ '../' if isArticle else '' }}css/style.css">
</head>
<body data-imprint="circular">

  <div class="container">
    <header class="pb-masthead">
      <a class="pb-masthead__brand" href="{{ '../' if isArticle else '' }}index.html">
        <div class="pb-endorsement">
          <span class="pb-endorsement__mark">
            <svg width="36" height="36" viewBox="0 0 80 80"><polygon points="40,5 65,22.5 65,57.5 40,75 15,57.5 15,22.5" fill="currentColor"/><text x="40" y="50" text-anchor="middle" font-family="Crimson Pro, Georgia, serif" font-size="28" font-weight="600" font-style="italic" fill="#FAF7F1">C</text></svg>
          </span>
          <div>
            <div class="pb-endorsement__name">The Fortnightly Circular</div>
          </div>
        </div>
      </a>
      <nav class="pb-masthead__nav">
        Vol. {{ site.volume }}<span>·</span>No. {{ site.issue }}<span>·</span>{{ site.season }}<span>·</span><a href="{{ '../' if isArticle else '' }}contributors.html"{% if title == 'Contributors' %} aria-current="page"{% endif %}>Contributors</a><span>·</span><a href="{{ site.signInUrl }}" data-signin>Sign in</a>
      </nav>
    </header>
  </div>

  {{ content | safe }}

  <section class="subscribe-section" aria-label="Subscribe">
    <div class="container">
      <div class="subscribe-section__inner">
        <h2 class="subscribe-section__heading">Subscribe to the Circular</h2>
        <p class="subscribe-section__dek">New numbers delivered fortnightly, by electronic post.</p>
        <form class="subscribe-form" id="subscribe-form"
              method="post"
              action="{{ site.platformApiUrl }}/subscribe"
              onsubmit="return false">
          <input type="email" name="email" placeholder="your@email.address" aria-label="Email address" required>
          <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-10000px">
          {% if site.turnstileSiteKey %}
          <div class="cf-turnstile subscribe-form__turnstile" data-sitekey="{{ site.turnstileSiteKey }}" data-size="flexible" data-theme="light"></div>
          {% endif %}
          <button type="submit">Subscribe</button>
        </form>
        <div class="subscribe-form__status" id="subscribe-status" aria-live="polite"></div>
      </div>
    </div>
  </section>

  <div class="container">
    <footer class="pb-footer">
      <a class="pb-footer__brand" href="https://proofbound.com">
        <span class="pb-footer__mark">
          <svg width="20" height="20" viewBox="0 0 80 80"><polygon points="40,5 65,22.5 65,57.5 40,75 15,57.5 15,22.5" fill="currentColor"/><path d="M22 30 L37 33 L37 50 L22 47 Z" fill="#FAF7F1"/><path d="M43 33 L58 30 L58 47 L43 50 Z" fill="#FAF7F1"/></svg>
        </span>
        <span class="pb-footer__wordmark">Proofbound</span>
      </a>
      <div class="pb-footer__meta">
        <a href="{{ '../' if isArticle else '' }}contributors.html">Contributors</a>
        <span>·</span>
        © 2026 Ensembio, Inc.
      </div>
    </footer>
  </div>

  <p class="print-footer">The Fortnightly Circular &middot; No. {{ site.issue }} &middot; {{ site.season }}</p>

  <!-- Supabase JS client (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  {% if site.turnstileSiteKey %}
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  {% endif %}
  <script>
    window.__CIRCULAR__ = {
      supabaseUrl:     "{{ site.supabaseUrl }}",
      supabaseAnonKey: "{{ site.supabaseAnonKey }}",
      platformApiUrl:  "{{ site.platformApiUrl }}",
      turnstileSiteKey:"{{ site.turnstileSiteKey }}"
    };
  </script>
  <script src="{{ '../' if isArticle else '' }}js/circular.js" defer></script>
</body>
</html>
