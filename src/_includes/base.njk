<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ pageTitle | default(site.title) }}{% endif %}</title>
  <meta name="description" content="{{ dek | default(description) | default(site.description) }}">
  <link rel="stylesheet" href="{{ '../' if isArticle else '' }}css/style.css">
</head>
<body>

  <header class="masthead">
    <a href="{{ '../' if isArticle else '' }}index.html" class="masthead__image-wrap">
      <img src="{{ '../' if isArticle else '' }}assets/circular-masthead-horizontal-clipped-nonames.jpg"
           alt="Karam &amp; Sprague&rsquo;s Fortnightly Circular &mdash; Conducted for the Benefit of Persons of Discernment &amp; Enquiring Disposition"
           class="masthead__image">
    </a>
    <div class="masthead__meta-bar">
      <span>Vol. {{ site.volume }} &middot; No. {{ site.issue }}</span>
      <span>{{ site.season }}</span>
    </div>
  </header>

  {% if isArticle %}
  <nav class="nav-bar" aria-label="Navigation">
    <div class="container">
      <div class="nav-bar__inner">
        <a href="../index.html">All Articles</a>
        <div class="nav-bar__actions">
          <a href="{{ site.signInUrl }}" data-signin>Sign in</a>
        </div>
      </div>
    </div>
  </nav>
  {% endif %}

  {{ content | safe }}

  <footer>
    <div class="container">
      <div class="footer__inner">
        <div class="footer__brand">{% if isArticle %}<a href="../index.html" style="color:inherit;text-decoration:none;">{% endif %}Karam &amp; Sprague&rsquo;s Fortnightly Circular{% if isArticle %}</a>{% endif %}</div>
        <div>Vol. {{ site.volume }}, No. {{ site.issue }} &middot; {{ site.season }}</div>
      </div>
    </div>
  </footer>

  <!-- Subscribe modal -->
  <div class="subscribe-modal" id="subscribe-modal" aria-hidden="true">
    <div class="subscribe-modal__backdrop"></div>
    <div class="subscribe-modal__dialog" role="dialog" aria-labelledby="subscribe-modal-title">
      <button class="subscribe-modal__close" aria-label="Close">&times;</button>
      <h2 id="subscribe-modal-title">Subscribe to the Circular</h2>
      <p class="subscribe-modal__dek">New issues delivered fortnightly to your inbox.</p>
      <form class="subscribe-modal__form" id="subscribe-form"
            method="post"
            action="{{ site.platformApiUrl }}/subscribe"
            onsubmit="return false">
        <input type="email" name="email" placeholder="Your email address" required>
        <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-10000px;display:none">
        <button type="submit" class="btn btn--filled">Subscribe</button>
      </form>
      <div class="subscribe-modal__status" id="subscribe-status"></div>
    </div>
  </div>

  <!-- Supabase JS client (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <!-- Runtime config (public keys only — safe for client-side) -->
  <script>
    window.__CIRCULAR__ = {
      supabaseUrl:    "{{ site.supabaseUrl }}",
      supabaseAnonKey:"{{ site.supabaseAnonKey }}",
      platformApiUrl: "{{ site.platformApiUrl }}"
    };
  </script>
  <script src="{{ '../' if isArticle else '' }}js/circular.js" defer></script>
</body>
</html>
