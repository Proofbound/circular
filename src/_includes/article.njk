---
layout: base.njk
isArticle: true
---
{% set allArticles = collections.articles %}
{% set currentIndex = -1 %}
{% for a in allArticles %}
  {% if a.url == page.url %}{% set currentIndex = loop.index0 %}{% endif %}
{% endfor %}
{% set prevArticle = allArticles[currentIndex - 1] if currentIndex > 0 else null %}
{% set nextArticle = allArticles[currentIndex + 1] if currentIndex < allArticles.length - 1 else null %}

<main>
  <div class="container">
    <article class="article-page">

      <header class="article-header">
        <div class="article-header__section">
          {{ section }}{% if subsection %} &middot; {{ subsection }}{% endif %}
        </div>
        <h1 class="article-header__title">{{ title }}</h1>
        {% if dek %}
        <p class="article-header__dek">{{ dek | safe }}</p>
        {% endif %}
        <p class="article-header__byline">
          By <strong>{{ author }}</strong>
          {% if subsection %}<span class="article-header__column">{{ subsection }}</span>{% endif %}
        </p>
        <hr class="article-header__rule">
      </header>

      {% if leadImage %}
      <figure class="article-figure article-figure--lead">
        <img src="{{ leadImage.src }}" alt="{{ leadImage.alt }}">
        {% if leadImage.caption %}<figcaption>{{ leadImage.caption | safe }}</figcaption>{% endif %}
      </figure>
      {% endif %}

      <div class="article-body{% if featured %} featured{% endif %}">
        {{ content | safe }}
      </div>

      <hr class="ornamental">

      <p class="contributor-note">
        <em>{{ author }} writes for</em> The Fortnightly Circular.
      </p>

      {% if prevArticle or nextArticle %}
      <nav class="article-continuation" aria-label="More in this number">
        {% if prevArticle %}
        <a href="{{ prevArticle.fileSlug }}.html" class="article-continuation__link article-continuation__link--prev">
          <small>← Previous</small>
          <span>{{ prevArticle.data.title }}</span>
        </a>
        {% endif %}
        {% if nextArticle %}
        <a href="{{ nextArticle.fileSlug }}.html" class="article-continuation__link article-continuation__link--next">
          <small>Next →</small>
          <span>{{ nextArticle.data.title }}</span>
        </a>
        {% endif %}
      </nav>
      {% endif %}

    </article>
  </div>
</main>
